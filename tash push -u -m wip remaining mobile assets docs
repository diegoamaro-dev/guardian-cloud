[32m+[m[32m      target.emitted_base64_length = Math.max([m
[32m+[m[32m        target.emitted_base64_length,[m
[32m+[m[32m        dup.emitted_base64_length,[m
[32m+[m[32m      );[m
[32m+[m[32m      target.next_chunk_index = Math.max([m
[32m+[m[32m        target.next_chunk_index,[m
[32m+[m[32m        dup.next_chunk_index,[m
[32m+[m[32m      );[m
[32m+[m[32m      target.recording_closed =[m
[32m+[m[32m        target.recording_closed || dup.recording_closed;[m
[32m+[m[32m      target.session_completed =[m
[32m+[m[32m        target.session_completed || dup.session_completed;[m
[32m+[m[32m      target.complete_attempts = Math.max([m
[32m+[m[32m        target.complete_attempts,[m
[32m+[m[32m        dup.complete_attempts,[m

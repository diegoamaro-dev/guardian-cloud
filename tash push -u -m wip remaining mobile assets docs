[32m+[m[32m      }[m
[32m+[m[32m      if (entryChanged) {[m
[32m+[m[32m        cleaned.sort((a, b) => a.chunk_index - b.chunk_index);[m
[32m+[m[32m        entry.chunks = cleaned;[m
[32m+[m[32m      }[m
[32m+[m[32m    }[m

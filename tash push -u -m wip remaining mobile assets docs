[32m+[m[32masync function normalizeQueueOnRecovery(): Promise<NormalizationReport> {[m
[32m+[m[32m  return queueMutate(q => {[m
[32m+[m[32m    const report: NormalizationReport = {[m
[32m+[m[32m      entries_collapsed: 0,[m
[32m+[m[32m      exact_duplicates_dropped: 0,[m
[32m+[m[32m      sessions_marked_corrupt: 0,[m
[32m+[m[32m      chunks_marked_failed: 0,[m
[32m+[m[32m    };[m
[32m+[m
[32m+[m[32m    // Step 1: collapse duplicate session_id entries.[m
[32m+[m[32m    const firstIdxBySession = new Map<string, number>();[m
[32m+[m[32m    for (let i = 0; i < q.length; i++) {[m
[32m+[m[32m      const sid = q[i]!.session_id;[m
[32m+[m[32m      const firstIdx = firstIdxBySession.get(sid);[m
[32m+[m[32m      if (firstIdx === undefined) {[m

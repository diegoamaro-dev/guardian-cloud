[32m+[m[32m          // (first) hash per group; mark it failed.[m
[32m+[m[32m          const seenHashes = new Set<string>();[m
[32m+[m[32m          for (const c of group) {[m
[32m+[m[32m            if (seenHashes.has(c.hash)) continue;[m
[32m+[m[32m            seenHashes.add(c.hash);[m
[32m+[m[32m            failedChunks.push({[m
[32m+[m[32m              ...c,[m
[32m+[m[32m              status: 'failed',[m
[32m+[m[32m              base64Slice: undefined,[m
[32m+[m[32m              last_error: {[m
[32m+[m[32m                status: 0,[m
[32m+[m[32m                code: 'CORRUPT_HASH_DIVERGENCE',[m
[32m+[m[32m                message:[m
[32m+[m[32m                  `chunk_index ${c.chunk_index} appeared with multiple hashes ` +[m
[32m+[m[32m                  `in persisted queue; entire session marked corrupt`,[m
[32m+[m[32m              },[m
[32m+[m[32m            });[m
[32m+[m[32m          }[m
[32m+[m[32m        }[m
[32m+[m[32m        failedChunks.sort((a, b) => a.chunk_index - b.chunk_index);[m
[32m+[m[32m        const droppedNow =[m
[32m+[m[32m          entry.chunks.length - failedChunks.length;[m
[32m+[m[32m        if (droppedNow > 0) report.exact_duplicates_dropped += droppedNow;[m
[32m+[m[32m        entry.chunks = failedChunks;[m
[32m+[m[32m        report.sessions_marked_corrupt++;[m
[32m+[m[32m        report.chunks_marked_failed += failedChunks.length;[m
[32m+[m[32m        continue;[m
[32m+[m[32m      }[m

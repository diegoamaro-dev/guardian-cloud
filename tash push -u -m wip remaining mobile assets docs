[32m+[m[32m      // No divergence — just dedup exact duplicates per chunk_index.[m
[32m+[m[32m      let entryChanged = false;[m
[32m+[m[32m      const cleaned: QueueChunk[] = [];[m
[32m+[m[32m      for (const group of groups.values()) {[m
[32m+[m[32m        if (group.length === 1) {[m
[32m+[m[32m          cleaned.push(group[0]!);[m
[32m+[m[32m          continue;[m
[32m+[m[32m        }[m
[32m+[m[32m        // Same chunk_index, same hash (already established above).[m
[32m+[m[32m        // Prefer an 'uploaded' chunk so we keep the remote_reference;[m
[32m+[m[32m        // otherwise the first occurrence wins.[m
[32m+[m[32m        const kept = group.find(c => c.status === 'uploaded') ?? group[0]!;[m

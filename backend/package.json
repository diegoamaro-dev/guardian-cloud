    "helmet": "^7.1.0",
    "jose": "^5.9.6",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.5.0",
    "@types/supertest": "^6.0.2",
    "jsonwebtoken": "^9.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",

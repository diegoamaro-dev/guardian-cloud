{
  "name": "guardian-cloud-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Guardian Cloud backend — sessions + chunks metadata service.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
